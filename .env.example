# Copy to .env and fill real values. .env is gitignored — never commit it.
#
#   cp .env.example .env

# SLURM account on your site
FLEET_ACCOUNT=lab

# Optional login name (default: $USER)
# FLEET_USER=

# Login hosts (defaults in code are dummy 10.0.0.x placeholders)
FLEET_OMNI_HOST=10.0.0.1
FLEET_PRECISION_HOST=10.0.0.2
